# Ignore build directories (generated by CMake)
build/
**/build/
.cache/

# Conan specific files
conanbuildinfo.cmake
conanbuildinfo.txt
conaninfo.txt
graph_info.json
conan.lock

# Ignore CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Makefile

# Ignore binary files
*.exe
*.out
*.app
*.o
*.a
*.so
*.dylib
*.lib
*.dll
*.pdb
*.obj

# Ignore IDE-specific files (optional, depending on your setup)
.vscode/
*.code-workspace
.idea/
*.iml

# Ignore OS-generated files
.DS_Store
Thumbs.db

# Ignore log and temporary files
*.log
*.tmp
*.bak
*.swp

# Ignore compiled Python files (if you use Python scripts)
__pycache__/
*.py[cod]

# Ignore test result files
Testing/
test_output/

# Ignore user-specific settings or editor files
*.user
*.suo
*.sln
r-type_server
r-type_client

# Ignore any other unwanted folders
# Add more folders if your project structure grows or changes
